{
  "name": "@kiraclaw/desktop",
  "productName": "KiraClaw",
  "private": true,
  "version": "0.1.2",
  "author": "KRAFTON AI",
  "description": "KiraClaw desktop shell",
  "main": "main.js",
  "files": [
    "main.js",
    "preload.js",
    "lib/**/*",
    "renderer/**/*",
    "assets/**/*",
    "icons/**/*",
    "package.json"
  ],
  "scripts": {
    "start": "electron .",
    "verify:bridge": "bash ../../scripts/verify_bridge_release.sh",
    "build:bridge": "electron-builder --config electron-builder.bridge.json",
    "build:bridge:mac": "electron-builder --mac --config electron-builder.bridge.json",
    "build:bridge:win": "electron-builder --win --config electron-builder.bridge.json",
    "deploy:bridge:mac": "electron-builder --mac --publish always --config electron-builder.bridge.json",
    "deploy:bridge:mac:skip-notarize": "electron-builder --mac --publish always --config electron-builder.bridge.skip-notarize.json",
    "deploy:bridge:win": "electron-builder --win --publish always --config electron-builder.bridge.json",
    "build:bridge:smoke": "electron-builder --mac --config electron-builder.bridge.smoke.json",
    "build:bridge:smoke:dir": "electron-builder --dir --mac --config electron-builder.bridge.smoke.json",
    "build:public": "electron-builder --config electron-builder.public.json",
    "build:public:mac": "electron-builder --mac --config electron-builder.public.json",
    "build:public:win": "electron-builder --win --config electron-builder.public.json",
    "deploy:public:mac": "electron-builder --mac --publish always --config electron-builder.public.json",
    "deploy:public:mac:skip-notarize": "electron-builder --mac --publish always --config electron-builder.public.skip-notarize.json",
    "deploy:public:win": "electron-builder --win --publish always --config electron-builder.public.json",
    "build:public:smoke:dir": "electron-builder --dir --mac --config electron-builder.public.json"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1"
  }
}
