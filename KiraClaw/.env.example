KIRACLAW_HOME_MODE=auto
KIRACLAW_PROVIDER=claude
KIRACLAW_MODEL=
KIRACLAW_MAX_TURNS=64
KIRACLAW_TOKEN_LIMIT=180000
KIRACLAW_BASH_TIMEOUT=900

# Providers:
# - claude: uses ANTHROPIC_API_KEY
# - openai: uses OPENAI_API_KEY
# - vertex_ai: uses GOOGLE_APPLICATION_CREDENTIALS / ADC
# `auto` home mode prefers ~/.kira when it already exists.

KIRACLAW_PRIMARY_CHANNEL=slack
KIRACLAW_SLACK_ENABLED=true
KIRACLAW_SLACK_BOT_TOKEN=
KIRACLAW_SLACK_APP_TOKEN=
KIRACLAW_SLACK_SIGNING_SECRET=
KIRACLAW_SLACK_TEAM_ID=
KIRACLAW_SLACK_ACK_TEXT=Working on it. I will reply in this thread when the run finishes.
KIRACLAW_PROACTIVE_ENABLED=true
KIRACLAW_PROACTIVE_INTERVAL_SECONDS=300
KIRACLAW_PROACTIVE_AUTO_DISPATCH=false
KIRACLAW_PROACTIVE_DEFAULT_CHANNEL_ID=

KIRACLAW_DESKTOP_APP_ENABLED=true
KIRACLAW_DESKTOP_CHAT_ENABLED=false
